# Copy to .env and fill in real values. .env is gitignored; this file is the template.
#
# NOTE: backend/config/settings.py does not read these yet (it's still on the
# Django boilerplate defaults: hardcoded SECRET_KEY, DEBUG=True, sqlite3).
# This file anticipates the PostgreSQL + Docker Compose setup described in
# PLAN.md / project_spec.md, for when settings.py is wired up to read from env.

# --- Django ---
DJANGO_SECRET_KEY=changeme
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
# Also used by the postgres service in docker-compose.yml (POSTGRES_DB/USER/PASSWORD).
DB_NAME=stackmap
DB_USER=stackmap
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# --- CORS (Angular frontend) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200
